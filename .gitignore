in_process_claims/
output/
history/

# ── Secrets / environment ─────────────────────────────────────────────────────
.env
.env.*
*.env

# ── Python bytecode ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*~

# ── Keep empty placeholder folders in git ─────────────────────────────────────
!assets/unolo_data/.gitkeep
!in_process_claims/.gitkeep
!output/.gitkeep
!history/.gitkeep
