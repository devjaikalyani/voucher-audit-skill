  "site_deputation_30_plus_days": {
    "applies_when": "Employee deputed on site for more than 30 days AND no company guest house arrangement",
    "applies_to": "Project Manager grade and above when monthly travel > 15 days (max Rs.7000)",
    "lodging_caps": {
      "PROJECT_MANAGER": {"A": 12000, "B": 10000, "C": 8000, "fooding": 7000},
      "ASST_MANAGER":    {"A": 10500, "B": 9000,  "C": 7000, "fooding": 6000},
      "ENGINEER":        {"A": 9000,  "B": 7500,  "C": 5000, "fooding": 5000},
      "TECHNICIAN":      {"A": 7000,  "B": 5500,  "C": 4000, "fooding": 4000}
    },
    "note": "If travel >15 days/month, fixed fooding policy applies, max Rs.7000 for Project Manager and above"
  },
  "petrol_charges": {
    "bike_per_km": 3,
    "car_per_km": 9
  },
  "proof_requirements": {
    "hotel":            ["Hotel tax invoice / bill", "Payment receipt"],
    "train":            ["PNR / e-ticket", "Receipt or fare proof"],
    "bus":              ["Bus ticket", "Receipt"],
    "flight":           ["Boarding pass or e-ticket", "Receipt"],
    "cab_auto":         ["Cab/auto receipt with ride ID, route, amount, date"],
    "food_with_stay":   ["Per-diem - no bills required, claim eligible only with overnight stay proof"],
    "food_without_stay":["Per-diem (over 12 hrs) - duration proof"],
    "other_expense":    ["Original receipt mandatory; monthly limit Rs.5,000"]
  },
  "category_rules": {
    "hospitality_entertainment": {
      "description": "Client/official entertainment, meals for external officials",
      "policy_status": "NOT covered under standard travel policy",
      "approval_required": "VP / GM pre-approval mandatory",
      "monthly_limit_inr": 5000,
      "audit_action": "Flag CONDITIONAL with note 'requires senior management pre-approval'"
    },
    "duplicate_receipts": {
      "rule": "Detect by ride ID, invoice number, txn ID, or exact amount+date+vendor match",
      "action": "REJECT duplicate; keep one valid copy"
    },
    "weak_proof_train": {
      "rule": "Internal debit voucher alone is insufficient for 2AC/1AC train claims",
      "action": "Flag CONDITIONAL pending PNR/e-ticket"
    },
    "checkout_day_food": {
      "rule": "On checkout day with no overnight stay, only without-stay (>12 hrs) rate applies",
      "action": "Reduce to half-day rate per designation"
    }
  },
  "audit_severity_levels": ["HIGH", "MEDIUM", "LOW"],
  "audit_status_values": ["APPROVE", "CONDITIONAL", "FLAG", "REJECT"]
